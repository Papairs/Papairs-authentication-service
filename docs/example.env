# ============================================
# PAPAIRS ENVIRONMENT CONFIGURATION
# ============================================
# Copy relevant sections to each service's .env file
# Structure: backend/<service>/.env

# ============================================
# AUTH SERVICE (backend/auth-service/.env)
# ============================================
PORT=8081
DB_URL=jdbc:mysql://your-host:3306/auth_db
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ============================================
# DOCS SERVICE (backend/docs-service/.env)
# ============================================
PORT=8082
DB_URL=jdbc:mysql://your-host:3306/docs_db
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Storage: "local" or "b2"
STORAGE_MODE=b2
STORAGE_LOCAL_PATH=./uploads

# Backblaze B2 (required if STORAGE_MODE=b2)
B2_BUCKET_NAME=your-bucket-name
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key

# ============================================
# AI SERVICE (backend/ai-service/.env)
# ============================================
PORT=3001
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# COLLABORATION SERVICE
# ============================================
# No .env required - uses docker-compose environment

# ============================================
# ORCHESTRATION SERVICE
# ============================================
# No .env required - uses docker-compose environment
# Service URLs configured in docker-compose.yml

# ============================================
# ROOT .env (optional, for docker-compose overrides)
# ============================================
# TZ=Europe/Copenhagen
# CORS_ALLOWED_ORIGIN=http://localhost:3000
